#!/bin/bash
#PBS -l walltime=100:00:00
#PBS -q default@pbs-m1.metacentrum.cz
#PBS -l select=1:ncpus=4:mem=10gb:scratch_local=200gb
#PBS -N pfam_chunk
#PBS -j oe

# Author: Iris Sammarco
# Date: 03/2026
# Aim: PBS array job to run hmmscan (Pfam-A) on one FASTA chunk of the TransDecoder long ORF peptide file. Called by trinotate_02_parallel_pfam_eggnog.bash.
# Do NOT submit directly — use the master script.
# Run: Called automatically by trinotate_02_parallel_pfam_eggnog.bash (qsub -J array)
# Input: Trinity.fasta.transdecoder_dir/longest_orfs.pep.split/chunk_pfam_NNN.pep
# Output: Trinity.fasta.transdecoder_dir/longest_orfs.pep.split/chunk_pfam_NNN.domtblout

set -euo pipefail

export PBS_ARRAY_INDEX=${PBS_ARRAY_INDEX:-1}
export PBS_O_WORKDIR=${PBS_O_WORKDIR:-$(pwd)}
# Debug log to verify array index is passed correctly; can be removed after validation
echo "DEBUG: PBS_ARRAY_INDEX='${PBS_ARRAY_INDEX}' PBS_ARRAYID='${PBS_ARRAYID:-unset}'" >> logs/pbs_debug_${PBS_ARRAY_INDEX}.txt
trap 'echo "[ERROR] ArrayID=${PBS_ARRAY_INDEX} failed on $(date)" >&2; exit 1' ERR # Metacentrum uses PBS_ARRAY_INDEX

export TMPDIR=$SCRATCHDIR
module add mambaforge
export CONDA_ENVS_PATH=/path/to/conda/envs
mamba activate trinotate_env

OUTDIR="/path/to/project/assembly/trinotate_output"
SPLIT_DIR="${OUTDIR}/Trinity.fasta.transdecoder_dir/longest_orfs.pep.split"
PFAM_HMM="/path/to/project/assembly/trinotate_data/Pfam-A.hmm"

CHUNK_ID=$(printf "%03d" ${PBS_ARRAY_INDEX})
PEP_CHUNK="${SPLIT_DIR}/chunk_pfam_${CHUNK_ID}.pep"
OUTFILE="${SPLIT_DIR}/chunk_pfam_${CHUNK_ID}.domtblout"

echo "[INFO] Array ${PBS_ARRAY_INDEX}: Using ${PEP_CHUNK} -> ${OUTFILE}"

cd "${OUTDIR}"
mkdir -p logs

# Sanity check
[[ -s "${PEP_CHUNK}" ]] || { echo "[FATAL] Missing chunk ${PEP_CHUNK}"; exit 1; }
[[ -s "${PFAM_HMM}" ]] || { echo "[FATAL] Missing Pfam HMM"; exit 1; }

# # Index HMM if needed
[[ ! -s "${PFAM_HMM}.h3f" ]] && hmmpress "${PFAM_HMM}"

# Run hmmscan
hmmscan --cpu 4 --domtblout "${OUTFILE}" \
    "${PFAM_HMM}" "${PEP_CHUNK}" \
    > "logs/pfam_chunk_${CHUNK_ID}.log" 2>&1

# Success marker
touch "${OUTFILE}.done"
echo "[SUCCESS] Pfam chunk ${CHUNK_ID} done: $(wc -l < "${OUTFILE}") domains"
